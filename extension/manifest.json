{
  "manifest_version": 3,
  "name": "Zedown — Markdown 速记 · 编辑 · 阅读",
  "version": "1.1.2",
  "description": "Zedown：侧边栏速记、全屏分屏编辑、纯净只读阅读，支持公式 / 图表 / 语法高亮 / 快捷键 —— 一个干净、专注的 Markdown 笔记插件。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Zedown 速记（点击打开侧边栏）",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "permissions": ["sidePanel", "storage", "contextMenus", "scripting", "activeTab"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": [
        "file:///*.md", "file:///*.MD", "file:///*.markdown", "file:///*.Markdown",
        "file:///*.mkd", "file:///*.mdown", "file:///*.mdwn", "file:///*.mkdn"
      ],
      "js": [
        "lib/md.js", "lib/highlight.js",
        "lib/vendor/katex/katex.min.js", "lib/vendor/mermaid.min.js",
        "lib/themes.js", "lib/sample.js",
        "lib/enhance.js", "lib/reader-view.js", "content/mdview.js"
      ],
      "css": ["lib/vendor/katex/katex.min.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/vendor/katex/fonts/*"],
      "matches": ["file:///*"]
    }
  ],
  "commands": {
    "open-panel": {
      "suggested_key": { "default": "Alt+Shift+M", "mac": "Alt+Shift+M" },
      "description": "开关 Zedown 侧边栏速记"
    },
    "open-editor": {
      "suggested_key": { "default": "Alt+Shift+E", "mac": "Alt+Shift+E" },
      "description": "打开 Zedown 全屏编辑器"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
